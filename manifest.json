{
  "manifest_version": 3,
  "name": "RingCentral Quick Dialer",
  "version": "3.0.1",
  "description": "Scrape phone numbers, queue them, and auto-dial via RingCentral Web Phone (WebRTC).",
  "key": "",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "identity",
    "offscreen",
    "alarms",
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "popup.html"
  },
  "host_permissions": [
    "https://platform.ringcentral.com/*",
    "https://*.ringcentral.com/*",
    "wss://*.ringcentral.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "RingCentral Quick Dialer (opens side panel)",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "offscreen.html",
        "dial.html",
        "dial.js",
        "scraper.js",
        "vendor/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
